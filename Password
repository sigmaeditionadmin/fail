<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Password Locker</title>
<style>
  body { font-family: Arial, sans-serif; padding: 20px; }
  #locked { display: block; }
  #content { display: none; }
</style>
</head>
<body>

<div id="locked">
  <h2>Enter Password to Proceed</h2>
  <input type="password" id="password" placeholder="Password" />
  <button onclick="checkPassword()">Submit</button>
  <p id="message"></p>
</div>

<div id="content">
  <h1>Welcome to Sigma Search!</h1>
  <p>This is your protected page.</p>
</div>

<script>
  const correctPassword = 'mypassword';  // Change this to your desired password

  function checkPassword() {
    const input = document.getElementById('password').value;
    const message = document.getElementById('message');

    if (input === correctPassword) {
      document.getElementById('locked').style.display = 'none';
      document.getElementById('content').style.display = 'block';
    } else {
      message.innerText = 'Incorrect password. Try again.';
    }
  }
</script>

</body>
</html>
